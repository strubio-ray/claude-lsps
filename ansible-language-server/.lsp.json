{
  "ansible": {
    "command": "bash",
    "args": [
      "${CLAUDE_PLUGIN_ROOT}/yaml-or-ansible-wrapper.sh",
      "--mode=ansible",
      "${CLAUDE_PLUGIN_ROOT}/proxy.json"
    ],
    "extensionToLanguage": {
      ".yaml": "ansible",
      ".yml": "ansible"
    },
    "restartOnCrash": false,
    "maxRestarts": 0
  }
}
